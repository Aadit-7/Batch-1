/* 1. Create Elements
   - Used to create new HTML elements using js

   Example
      let li = document.createElement("li");
      li.innerText = "New Item";


2. Add Elements to DOM

   Example
      let ul = document.querySelector("ul");
      ul.appendChild(li);


3. Remove Elements

   Example
      li.remove();

      OR

      ul.removeChild(li);


4. Class Manipulation

   Example
      li.classList.add("active");
      li.classList.remove("active");



5. Event on Dynamic Elements


li.addEventListener("click", () => {
  console.log("Item clicked");
});


Mini Example


let button = document.querySelector("#btn");
let ul = document.querySelector("ul");

button.addEventListener("click", () => {
  let li = document.createElement("li");
  li.innerText = "New Task";

  ul.appendChild(li);
});


Click → New item added to list






 */